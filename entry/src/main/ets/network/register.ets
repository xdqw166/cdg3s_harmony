import { HOST } from "../config"
import { RegisterRequest, RegisterResponse } from "./dto"
import { http } from "@kit.NetworkKit"

export interface RegisterAttribute {
  username: string
  password: string
  onSuccess?: (msg: string) => void
  onFail?: (msg: string) => void
}

export function register(attr: RegisterAttribute) {
  const url = `http://${HOST}/auth/register`
  const httpRequest = http.createHttp()

  const requestData: RegisterRequest = {
    username: attr.username,
    password: attr.password
  }

  httpRequest.request(url, {
    method: http.RequestMethod.POST,
    header: {
      'Content-Type': 'application/json'
    },
    extraData: JSON.stringify(requestData)
  }, (err: BusinessError, res: http.HttpResponse) => {
    httpRequest.destroy()

    if (err) {
      if (attr.onFail) attr.onFail(`зҪ‘з»ңй”ҷиҜҜпјҡ${err.message}`)
      return
    }
    try {
      const response = JSON.parse(res.result as string) as RegisterResponse
      if (response.success) {
        if (attr.onSuccess) attr.onSuccess(response.message || 'жіЁеҶҢжҲҗеҠҹ')
      } else {
        if (attr.onFail) attr.onFail(response.message || 'жіЁеҶҢеӨұиҙҘ')
      }
    } catch (e) {
      if (attr.onFail) attr.onFail(`жіЁеҶҢеӨұиҙҘпјҡ${e}`)
    }
  })
}
